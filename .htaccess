# Film ze Snu — konfiguracja serwera

# Ochrona katalogow
Options -Indexes

# Zabron dostepu do plikow konfiguracji
<Files "klucz_api.php">
    Require all denied
</Files>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Zabron bezposredniego dostepu do klas, konfiguracji i fragmentow
    RewriteRule ^konfiguracja/ - [F,L]
    RewriteRule ^klasy/ - [F,L]
    RewriteRule ^fragmenty/ - [F,L]

    # Zezwol na dostep do projekty/ (tam sa media)
    RewriteRule ^projekty/.+\.(jpg|jpeg|png|mp3|mp4|webm|json)$ - [L]

    # Zezwol na dostep do pliki/sny/ (publiczne media snów)
    RewriteRule ^pliki/sny/.+\.(webp|jpg|jpeg|mp4)$ - [L]

    # ── Strona "Jak to dziala?" ──
    RewriteRule ^jak-to-dziala/?$ jak-to-dziala.php [L,QSA]

    # ── Podstrony snów ──
    # Wszystkie sny (wszystkie jezyki)
    RewriteRule ^sny/wszystkie/?$ sny.php?wszystkie=1 [L,QSA]

    # Konkretny sen: /sny/2026/03/16/tytul-snu
    RewriteRule ^sny/([0-9]{4})/([0-9]{2})/([0-9]{2})/([a-z0-9-]+)/?$ sen.php?rok=$1&miesiac=$2&dzien=$3&slug=$4 [L,QSA]

    # Lista snów z danego dnia: /sny/2026/03/16
    RewriteRule ^sny/([0-9]{4})/([0-9]{2})/([0-9]{2})/?$ sny.php?rok=$1&miesiac=$2&dzien=$3 [L,QSA]

    # Lista snów z danego miesiaca: /sny/2026/03
    RewriteRule ^sny/([0-9]{4})/([0-9]{2})/?$ sny.php?rok=$1&miesiac=$2 [L,QSA]

    # Lista snów z danego roku: /sny/2026
    RewriteRule ^sny/([0-9]{4})/?$ sny.php?rok=$1 [L,QSA]

    # Glowna lista snów: /sny
    RewriteRule ^sny/?$ sny.php [L,QSA]
</IfModule>

# Kompresja
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>

# Cache statycznych zasobow
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css              "access plus 1 week"
    ExpiresByType image/jpeg            "access plus 1 month"
    ExpiresByType image/webp            "access plus 1 month"
    ExpiresByType video/mp4             "access plus 1 month"
    ExpiresByType audio/mpeg            "access plus 1 month"
</IfModule>

# Naglowki bezpieczenstwa
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
